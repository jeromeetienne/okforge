{
	"name": "okforge-webview",
	"version": "1.0.0",
	"description": "Static OKF webview generator and deploy scripts.",
	"type": "module",
	"private": true,
	"scripts": {
		"build": "tsx ../../src/cli.ts webview generate ../../.okf -o dist",
		"open": "npm run build && open dist/index.html",
		"deploy": "npm run build && bash ../../scripts/webview_deploy.sh"
	}
}
