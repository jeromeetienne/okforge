{
	"name": "okforge",
	"version": "1.0.11",
	"description": "Open Knowledge Format (OKF) skill for Claude Code — deterministic okf bundle mechanics and a Stop-hook nudge.",
	"type": "module",
	"bin": {
		"okforge": "dist/cli.js"
	},
	"main": "dist/cli.js",
	"types": "dist/cli.d.ts",
	"files": [
		"dist",
		"dotclaude_folder",
		"LICENSE"
	],
	"engines": {
		"node": ">=20.12"
	},
	"scripts": {
		"okforge": "tsx src/cli.ts",
		"symlink:dotclaude": "bash scripts/symlink_dotclaude.sh",
		"webview:build": "cd contribs/webview && npm run build",
		"webview:deploy": "cd contribs/webview && npm run deploy",
		"webview:open": "cd contribs/webview && npm run open",
		"typecheck": "tsc --noEmit",
		"test": "node --import tsx --test 'tests/**/*.test.ts'",
		"test:watch": "node --import tsx --test --watch 'tests/**/*.test.ts'",
		"build": "tsc -p tsconfig.build.json && npm run build:assets",
		"build:assets": "node -e \"require('node:fs').cpSync('src/webview/template','dist/webview/template',{recursive:true})\"",
		"publish:all": "npm run build && npm version patch && npm publish"
	},
	"author": {
		"name": "Jerome Etienne",
		"email": "jerome.etienne@gmail.com"
	},
	"license": "MIT",
	"keywords": [
		"claude-code",
		"okf",
		"open-knowledge-format",
		"knowledge-bundle",
		"skill"
	],
	"dependencies": {
		"chalk": "^5.3.0",
		"commander": "^12.1.0",
		"marked": "^18.0.5",
		"zod": "^3.23.8"
	},
	"devDependencies": {
		"@types/node": "^22.10.0",
		"tsx": "^4.19.2",
		"typescript": "^5.7.2"
	}
}
